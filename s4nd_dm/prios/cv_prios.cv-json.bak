            "_cacheDirty": false,
            "_lastSourceHash": "{\"sourceIds\":[],\"fieldExclusions\":[],\"fieldAliases\":{},\"selectedTable\":{\"connect_key\":\"1775066342937@@127.0.0.1@CLICKHOUSE@s4nd_dwh\",\"instanceName\":\"CLICKHOUSE\",\"database\":\"s4nd_dwh\",\"schema\":\"\",\"table\":\"zs4nd_d47\",\"dbType\":\"Clickhouse\",\"table_type\":\"TABLE\",\"metadata\":{\"table_schema\":\"s4nd_dwh\",\"table_name\":\"zs4nd_d47\",\"table_comment\":\"{\\\"app\\\": \\\"asapBI\\\",\\r\\n\\r\\n \\\"descr\\\": \\\"ПРиОС - факт\\\",\\r\\n\\r\\n \\\"folder\\\": \\\"tables/prios\\\"\\r\\n}\",\"table_type\":\"TABLE\"},\"jsonComment\":{\"app\":\"asapBI\",\"descr\":\"ПРиОС - факт\",\"folder\":\"tables/prios\"}}}",
            "selected": false,
            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Projection_zs4nd_d47\n-- =========================================\n-- Блок: Projection_zs4nd_d47 (projection)\n-- Тип: ClickHouse Parameterized View\n-- CV: cv_prios\n-- База данных: s4nd_dwh\n-- =========================================\n\nCREATE OR REPLACE VIEW s4nd_dwh.\"cv_prios$projection_zs4nd_d47\"(\n  \"address\" String COMMENT '2.14 Адрес реализации проекта.',\n  \"budget\" Decimal(17, 2) COMMENT '2.28 Бюджет проекта всего.',\n  \"chisl_max\" Int32 COMMENT '2.16 Максимальная численность, ШЕ (штатных единиц).',\n  \"cnt_gbl\" String COMMENT '2.6 Количество ГБЛ (генерирующих безопасных объектов).',\n  \"date_finans\" Date COMMENT '2.26 Фактическая дата выделения финансирования.',\n  \"date_from\" Date COMMENT 'Дата начала действия версии. Обязательное поле.',\n  \"date_norm_zav\" Date COMMENT '2.23 Нормативная дата завершения рассмотрения.',\n  \"date_realize\" Date COMMENT '2.17 Планируемая дата реализации проекта.',\n  \"date_to\" Nullable(Date) COMMENT 'Дата окончания действия версии. NULL означает \"действует бессрочно\".',\n  \"date_vipoln_otl_usl\" Date COMMENT '2.30.2 Дата выполнения отлагательного условия.',\n  \"date_zav_rassm\" Date COMMENT '2.22 Плановая дата завершения рассмотрения (устанавливается рук-вом УБ ФД).',\n  \"doc_link\" String COMMENT 'Ссылка на документацию по проекту',\n  \"executor\" String COMMENT '2.2 Исполнитель проекта (ФИО или подразделение).',\n  \"fdate_post\" Date COMMENT '2.20 Планируемая дата реализации проекта.',\n  \"fdate_zav\" Date COMMENT '2.21 Фактическая дата завершения рассмотрения проекта УБ ФД.',\n  \"fin_1_year\" Int32 COMMENT '2.27 Первый год, на который было выделено финансирования (20NN).',\n  \"fin_plan_ahr_0\" Decimal(17, 2) COMMENT '2.29 Плановый объем финансирования АХР - 20NN.',\n  \"fin_plan_ahr_1\" Decimal(17, 2) COMMENT '2.31 Плановый объем финансирования АХР - 20NN+1.',\n  \"fin_plan_ahr_2\" Decimal(17, 2) COMMENT '2.33 Плановый объем финансирования АХР - 20NN+2.',\n  \"fin_plan_kv_0\" Decimal(17, 2) COMMENT '2.30 Плановый объем финансирования КВ - 20NN.',\n  \"fin_plan_kv_1\" Decimal(17, 2) COMMENT '2.32 Плановый объем финансирования КВ - 20NN+1.',\n  \"fin_plan_kv_2\" Decimal(17, 2) COMMENT '2.34 Плановый объем финансирования КВ - 20NN+2.',\n  \"first_column\" Int32,\n  \"fm_area\" String COMMENT '2.9 ПФМ основной ТП (обозначение площадки).',\n  \"format_tp\" String COMMENT '2.5 Формат ТП (технологического передела).',\n  \"full_format\" String COMMENT '2.4 Полный формат проекта (описание типа объекта).',\n  \"funds_ctr\" String COMMENT '2.9 ПФМ основной ТП (аналогично fm_area).',\n  \"funds_ctr_shtxt\" String COMMENT '2.11 Краткое наименование ТП.',\n  \"funds_ctr_union\" String COMMENT '2.10 ПФМ объединяемых ТП (перечисление через запятую).',\n  \"id\" String COMMENT '2.0 Уникальный идентификатор версии записи',\n  \"is_deleted\" UInt8 COMMENT 'Флаг логического удаления. 1 — версия исключена из активного учёта, но сохранена в истории.',\n  \"is_finans\" String COMMENT '2.24 Требуется ли финансирование проекта? (да/нет).',\n  \"otlag_usl\" String COMMENT '2.30.1 Тип отлагательного условия.',\n  \"prior_rassm\" String COMMENT '2.8 Приоритетность рассмотрения (высокий, средний, низкий).',\n  \"project\" String COMMENT '2.1 Уникальный код проекта.',\n  \"project_plan\" String COMMENT '2.1 Уникальный код проекта - плановый',\n  \"project_vid\" String COMMENT '2.3 Вид проекта (например, капитальный ремонт, строительство).',\n  \"region\" String COMMENT '2.13 Регион (уточнённое название).',\n  \"remark\" String COMMENT '2.18 Дополнительный комментарий.',\n  \"s_tp\" String COMMENT '2.15 Площадь ТП, кв.м.',\n  \"status\" String COMMENT '2.19 Текущий статус рассмотрения проекта.',\n  \"status_finans\" String COMMENT '2.25 Статус выделения финансирования?',\n  \"subject\" String COMMENT '2.12 Субъект Российской Федерации.',\n  \"vid_rassm\" String COMMENT '2.7 Вид рассмотрения (плановый, внеплановый).'\n)\nstep_auto AS (\nSELECT\n  \"address\",\n  \"budget\",\n  \"chisl_max\",\n  \"cnt_gbl\",\n  \"date_finans\",\n  \"date_from\",\n  \"date_norm_zav\",\n  \"date_realize\",\n  \"date_to\",\n  \"date_vipoln_otl_usl\",\n  \"date_zav_rassm\",\n  \"doc_link\",\n  \"executor\",\n  \"fdate_post\",\n  \"fdate_zav\",\n  \"fin_1_year\",\n  \"fin_plan_ahr_0\",\n  \"fin_plan_ahr_1\",\n  \"fin_plan_ahr_2\",\n  \"fin_plan_kv_0\",\n  \"fin_plan_kv_1\",\n  \"fin_plan_kv_2\",\n  \"first_column\",\n  \"fm_area\",\n  \"format_tp\",\n  \"full_format\",\n  \"funds_ctr\",\n  \"funds_ctr_shtxt\",\n  \"funds_ctr_union\",\n  \"id\",\n  \"is_deleted\",\n  \"is_finans\",\n  \"otlag_usl\",\n  \"prior_rassm\",\n  \"project\",\n  \"project_plan\",\n  \"project_vid\",\n  \"region\",\n  \"remark\",\n  \"s_tp\",\n  \"status\",\n  \"status_finans\",\n  \"subject\",\n  \"vid_rassm\"\nFROM s4nd_dwh.zs4nd_d47\n)\nSELECT \n  \"address\",\n  \"budget\",\n  \"chisl_max\",\n  \"cnt_gbl\",\n  \"date_finans\",\n  \"date_from\",\n  \"date_norm_zav\",\n  \"date_realize\",\n  \"date_to\",\n  \"date_vipoln_otl_usl\",\n  \"date_zav_rassm\",\n  \"doc_link\",\n  \"executor\",\n  \"fdate_post\",\n  \"fdate_zav\",\n  \"fin_1_year\",\n  \"fin_plan_ahr_0\",\n  \"fin_plan_ahr_1\",\n  \"fin_plan_ahr_2\",\n  \"fin_plan_kv_0\",\n  \"fin_plan_kv_1\",\n  \"fin_plan_kv_2\",\n  \"first_column\",\n  \"fm_area\",\n  \"format_tp\",\n  \"full_format\",\n  \"funds_ctr\",\n  \"funds_ctr_shtxt\",\n  \"funds_ctr_union\",\n  \"id\",\n  \"is_deleted\",\n  \"is_finans\",\n  \"otlag_usl\",\n  \"prior_rassm\",\n  \"project\",\n  \"project_plan\",\n  \"project_vid\",\n  \"region\",\n  \"remark\",\n  \"s_tp\",\n  \"status\",\n  \"status_finans\",\n  \"subject\",\n  \"vid_rassm\"\nFROM step_auto;\n",
            "commentSql": "ALTER TABLE s4nd_dwh.\"cv_prios$projection_zs4nd_d47\" MODIFY COMMENT '{\n  \"app\": \"asapBI\",\n  \"descr\": \"отчет ПРиОС\",\n  \"type\": \"VIEW\",\n  \"folder\": \"git_prj/s4nd_dm/prios\",\n  \"fields\": {\n    \"address\": \"2.14 Адрес реализации проекта.\",\n    \"budget\": \"2.28 Бюджет проекта всего.\",\n    \"chisl_max\": \"2.16 Максимальная численность, ШЕ (штатных единиц).\",\n    \"cnt_gbl\": \"2.6 Количество ГБЛ (генерирующих безопасных объектов).\",\n    \"date_finans\": \"2.26 Фактическая дата выделения финансирования.\",\n    \"date_from\": \"Дата начала действия версии. Обязательное поле.\",\n    \"date_norm_zav\": \"2.23 Нормативная дата завершения рассмотрения.\",\n    \"date_realize\": \"2.17 Планируемая дата реализации проекта.\",\n    \"date_to\": \"Дата окончания действия версии. NULL означает \\\"действует бессрочно\\\".\",\n    \"date_vipoln_otl_usl\": \"2.30.2 Дата выполнения отлагательного условия.\",\n    \"date_zav_rassm\": \"2.22 Плановая дата завершения рассмотрения (устанавливается рук-вом УБ ФД).\",\n    \"doc_link\": \"Ссылка на документацию по проекту\",\n    \"executor\": \"2.2 Исполнитель проекта (ФИО или подразделение).\",\n    \"fdate_post\": \"2.20 Планируемая дата реализации проекта.\",\n    \"fdate_zav\": \"2.21 Фактическая дата завершения рассмотрения проекта УБ ФД.\",\n    \"fin_1_year\": \"2.27 Первый год, на который было выделено финансирования (20NN).\",\n    \"fin_plan_ahr_0\": \"2.29 Плановый объем финансирования АХР - 20NN.\",\n    \"fin_plan_ahr_1\": \"2.31 Плановый объем финансирования АХР - 20NN+1.\",\n    \"fin_plan_ahr_2\": \"2.33 Плановый объем финансирования АХР - 20NN+2.\",\n    \"fin_plan_kv_0\": \"2.30 Плановый объем финансирования КВ - 20NN.\",\n    \"fin_plan_kv_1\": \"2.32 Плановый объем финансирования КВ - 20NN+1.\",\n    \"fin_plan_kv_2\": \"2.34 Плановый объем финансирования КВ - 20NN+2.\",\n    \"fm_area\": \"2.9 ПФМ основной ТП (обозначение площадки).\",\n    \"format_tp\"