            "sqlScript": "-- =========================================\n-- ФУНКЦИЯ ДЛЯ БЛОКА: Projection_table1_pg\n-- =========================================\n-- Блок: Projection_table1_pg (projection)\n-- ID: projection_1775636267420\n-- CV: p_s\n-- Схема: analytics\n-- =========================================\n\nCREATE OR REPLACE FUNCTION demo.analytics.\"p_s$projection_table1_pg\"(\n  p_params JSONB DEFAULT '{}'\n)\nRETURNS TABLE(\n  \"amount\" NUMERIC,\n  \"country_code\" CHAR,\n  \"created_at\" TIMESTAMP WITH TIME ZONE,\n  \"id\" BIGINT,\n  \"is_active\" BOOLEAN,\n  \"metadata\" JSONB,\n  \"status\" VARCHAR,\n  \"t1_f1\" VARCHAR,\n  \"tags\" pg_catalog.text[],\n  \"updated_at\" TIMESTAMP WITH TIME ZONE,\n  \"user_id\" UUID\n)\nSTABLE\nAS $$\nDECLARE\n  _sql TEXT;\nBEGIN\n-- Функция для блока: Projection_table1_pg\n-- Тип блока: projection\n-- CV: p_s\n-- База данных: demo\n-- Схема: analytics\n  _sql := $inner$\n      -- Блок: Projection_table1_pg (projection)\n      SELECT\n        \"amount\",\n        \"country_code\"::pg_catalog.character,\n        \"created_at\"::pg_catalog.timestamp with time zone,\n        \"id\",\n        \"is_active\",\n        \"metadata\",\n        \"status\",\n        \"t1_f1\",\n        \"tags\"::pg_catalog.text[],\n        \"updated_at\"::pg_catalog.timestamp with time zone,\n        \"user_id\"::pg_catalog.uuid\n      FROM analytics.table1_pg;\n    \n  $inner$;\n  RETURN QUERY EXECUTE _sql USING p_params;\nEND;\n$$ LANGUAGE plpgsql;\n\n\n"
