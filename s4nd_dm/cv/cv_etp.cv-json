imk\" String COMMENT 'Признак возмещения/компенсации затрат',\n  \"zs4repmod\" String COMMENT 'Режим отчета/модель (Z-поле)',\n  \"zs4repseg\" String COMMENT 'Сегмент отчётности',\n  \"zs4sbaflg\" String COMMENT 'Флаг SBA (Special Business Area)',\n  \"zs4sctr\" String COMMENT 'Статистический центр затрат',\n  \"zs4sfrtrp\" String COMMENT 'Доп. тип формата отчёта',\n  \"zs4spcity\" String COMMENT 'Специальный город/локация',\n  \"zs4spcldt\" Date COMMENT 'Дата закрытия периода/объекта',\n  \"zs4spfdis\" String COMMENT 'Специальное распределение/деление',\n  \"zs4spfrmt\" String COMMENT 'Специальный формат данных',\n  \"zs4spopdt\" Date COMMENT 'Дата открытия периода/объекта',\n  \"zs4spreg\" String COMMENT 'Специальный регион',\n  \"zs4sprgrp\" String COMMENT 'Группа специальных регионов',\n  \"zs4sprldt\" Date COMMENT 'Дата релиза/утверждения',\n  \"zs4spsudt\" Date COMMENT 'Дата создания/обновления записи',\n  \"zs4sptrdt\" Date COMMENT 'Дата транзакции (спец.)',\n  \"zs4spwsts\" String COMMENT 'Статус работы/жизненного цикла',\n  \"zs4spwt1\" String COMMENT 'Весовой коэффициент 1',\n  \"zs4spwt2\" String COMMENT 'Весовой коэффициент 2',\n  \"zs4srctyp\" String COMMENT 'Тип источника данных',\n  \"zs4trggrp\" String COMMENT 'Группа целевых значений',\n  \"zs4vers\" String COMMENT 'Версия данных/среза'\n)\nAS WITH {ctx:String} AS ctx,\nstep_auto AS (\nSELECT\n  \"act_md_fctr_q_avg__act_months\",\n  \"act_sq_q__p_sq_per\",\n  \"act_sq_q__p_sq_saldo\",\n  \"act_sq_q_avg__p_add_quarter\",\n  \"act_sq_q_avg__prev_month\",\n  \"amount\",\n  \"amount_cc\",\n  \"asset\",\n  \"asset_clas\",\n  \"asset_main\",\n  \"bpartner\",\n  \"calday\",\n  \"calmonth\",\n  \"calquart_act\",\n  \"calquart_fltr_fnl\",\n  \"calquart1\",\n  \"calquarter\",\n  \"calyear\",\n  \"cmmt_item\",\n  \"cmmt_item__zs4citype__nav\",\n  \"co_area\",\n  \"comp_code\",\n  \"curr_cc\",\n  \"currency\",\n  \"flg_avg\",\n  \"fm_area\",\n  \"func_area\",\n  \"fund\",\n  \"funds_ctr\",\n  \"infoprov\",\n  \