            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Union_8\n-- =========================================\n-- Блок: Union_8 (union)\n-- Тип: ClickHouse Parameterized View\n-- CV: pp_u_pa_s\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"pp_u_pa_s$union_8\"(\n  \"id\" VARCHAR COMMENT 'Уникальный идентификатор записи (автоинкремент)',\n  \"user_id\" VARCHAR COMMENT 'ID пользователя (UUID)',\n  \"metadata\" VARCHAR COMMENT 'Гибкие метаданные в формате JSONB',\n  \"created_at\" VARCHAR COMMENT 'Дата и время создания записи (с часовым поясом)',\n  \"updated_at\" VARCHAR COMMENT 'Дата последнего обновления записи',\n  \"country_code\" VARCHAR COMMENT 'Код страны (ISO 3166-1 alpha-2: RU, US)',\n  \"tags\" VARCHAR COMMENT 'Массив тегов или категорий',\n  \"t1_f1\" VARCHAR COMMENT 'Произвольное текстовое поле (название или описание)',\n  \"status\" VARCHAR COMMENT 'Статус обработки: new, processed, error',\n  \"amount\" VARCHAR COMMENT 'Сумма транзакции с точностью до 2 знаков',\n  \"is_active\" VARCHAR COMMENT 'Флаг активности записи (NULL = неизвестно)',\n  \"session_id\" VARCHAR COMMENT 'Уникальный идентификатор пользовательской сессии (UUID)',\n  \"http_status\" VARCHAR COMMENT 'HTTP код ответа (через ENUM тип)',\n  \"ip_address\" VARCHAR COMMENT 'IP-адрес клиента (тип INET поддерживает IPv4/IPv6)',\n  \"referrer\" VARCHAR COMMENT 'URL страницы перехода (может быть NULL)',\n  \"request_time\" VARCHAR COMMENT 'Время запроса с точностью до миллисекунд (с часовым поясом)',\n  \"response_time_ms\" VARCHAR COMMENT 'Время обработки запроса в миллисекундах',\n  \"url\" VARCHAR COMMENT 'Полный URL запрашиваемой страницы',\n  \"bytes_sent\" VARCHAR COMMENT 'Размер ответа сервера в байтах',\n  \"user_agent\" VARCHAR COMMENT 'Строка User-Agent браузера или клиента',\n  \"is_bot\" VARCHAR COMMENT 'Флаг: является ли запрос ботом'\n) AS\nWITH \nifNull({ctx:String}, '{}') AS ctx_init,\n  if(isValidJSON(ctx_init), ctx_init, '{}') AS ctx_clean,\n  isValidJSON(ctx_init) AS is_ctx_ok,\n  ifNull(JSONExtractString(ctx_clean, 'test_var'), 'Москва') AS test_var,\n  toJSONString((test_var)::Tuple(test_var String)) AS ctx,\nstep_auto AS (\nSELECT\n    \"id\" AS \"id\",\n    \"user_id\" AS \"user_id\",\n    \"metadata\" AS \"metadata\",\n    \"created_at\" AS \"created_at\",\n    \"updated_at\" AS \"updated_at\",\n    \"country_code\" AS \"country_code\",\n    \"tags\" AS \"tags\",\n    \"t1_f1\" AS \"t1_f1\",\n    \"status\" AS \"status\",\n    \"amount\" AS \"amount\",\n    \"is_active\" AS \"is_active\",\n    NULL AS \"session_id\",\n    NULL AS \"http_status\",\n    NULL AS \"ip_address\",\n    NULL AS \"referrer\",\n    NULL AS \"request_time\",\n    NULL AS \"response_time_ms\",\n    NULL AS \"url\",\n    NULL AS \"bytes_sent\",\n    NULL AS \"user_agent\",\n    NULL AS \"is_bot\"\n  FROM analytics.\"pp_u_pa_s$projection_table1_pg\"(ctx = ctx)\nUNION\nSELECT\n    NULL AS \"id\",\n    NULL AS \"user_id\",\n    NULL AS \"metadata\",\n    NULL AS \"created_at\",\n    NULL AS \"updated_at\",\n    NULL AS \"country_code\",\n    NULL AS \"tags\",\n    NULL AS \"t1_f1\",\n    \"http_status\" AS \"status\",\n    NULL AS \"amount\",\n    NULL AS \"is_active\",\n    \"session_id\" AS \"session_id\",\n    \"http_status\" AS \"http_status\",\n    \"ip_address\" AS \"ip_address\",\n    \"referrer\" AS \"referrer\",\n    \"request_time\" AS \"request_time\",\n    \"response_time_ms\" AS \"response_time_ms\",\n    \"url\" AS \"url\",\n    \"bytes_sent\" AS \"bytes_sent\",\n    \"user_agent\" AS \"user_agent\",\n    \"is_bot\" AS \"is_bot\"\n  FROM analytics.\"pp_u_pa_s$projection_table2_pg\"(ctx = ctx)\n)\nSELECT \n  \"id\",\n  \"user_id\",\n  \"metadata\",\n  \"created_at\",\n  \"updated_at\",\n  \"country_code\",\n  \"tags\",\n  \"t1_f1\",\n  \"status\",\n  \"amount\",\n  \"is_active\",\n  \"session_id\",\n  \"http_status\",\n  \"ip_address\",\n  \"referrer\",\n  \"request_time\",\n  \"response_time_ms\",\n  \"url\",\n  \"bytes_sent\",\n  \"user_agent\",\n  \"is_bot\"\nFROM step_auto;\n",
            "savedCursorLine": 28,
            "savedCursorColumn": 28,
            "savedScrollTop": 450,
            "savedScrollLeft": 0
        },
