            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Projection_table1_pg\n-- =========================================\n-- Блок: Projection_table1_pg (projection)\n-- Тип: ClickHouse Parameterized View\n-- CV: pp_u_pa_s\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"pp_u_pa_s$projection_table1_pg\"(\n  \"amount\" numeric COMMENT 'Сумма транзакции с точностью до 2 знаков',\n  \"country_code\" character COMMENT 'Код страны (ISO 3166-1 alpha-2: RU, US)',\n  \"created_at\" timestamp with time zone COMMENT 'Дата и время создания записи (с часовым поясом)',\n  \"id\" bigint COMMENT 'Уникальный идентификатор записи (автоинкремент)',\n  \"is_active\" boolean COMMENT 'Флаг активности записи (NULL = неизвестно)',\n  \"metadata\" jsonb COMMENT 'Гибкие метаданные в формате JSONB',\n  \"status\" varchar COMMENT 'Статус обработки: new, processed, error',\n  \"t1_f1\" varchar COMMENT 'Произвольное текстовое поле (название или описание)',\n  \"tags\" text[] COMMENT 'Массив тегов или категорий',\n  \"updated_at\" timestamp with time zone COMMENT 'Дата последнего обновления записи',\n  \"user_id\" uuid COMMENT 'ID пользователя (UUID)'\n) AS\nWITH \nifNull({ctx:String}, '{}') AS ctx_init,\n  if(isValidJSON(ctx_init), ctx_init, '{}') AS ctx_clean,\n  isValidJSON(ctx_init) AS is_ctx_ok,\n  ifNull(JSONExtractString(ctx_clean, 'test_var'), 'Москва') AS test_var,\n  toJSONString((test_var)::Tuple(test_var String)) AS ctx,\nstep_auto AS (\nSELECT\n  \"amount\",\n  \"country_code\",\n  \"created_at\",\n  \"id\",\n  \"is_active\",\n  \"metadata\",\n  \"status\",\n  \"t1_f1\",\n  \"tags\",\n  \"updated_at\",\n  \"user_id\"\nFROM analytics.table1_pg\n)\nSELECT \n  \"amount\",\n  \"country_code\",\n  \"created_at\",\n  \"id\",\n  \"is_active\",\n  \"metadata\",\n  \"status\",\n  \"t1_f1\",\n  \"tags\",\n  \"updated_at\",\n  \"user_id\"\nFROM step_auto;\n",
