            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Semantics\n-- =========================================\n-- Блок: Semantics (semantics)\n-- Тип: ClickHouse Parameterized View\n-- CV: test\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"test\" AS\nWITH step_auto AS (\nSELECT\n  \"created_at\" AS \"created_at\",\n  \"t1_f1\" AS \"t1_f1\"\nFROM analytics.\"test$projection_table1_ch\"\nGROUP BY \"created_at\", \"t1_f1\"\n)\nSELECT *\nFROM step_auto;\n"
