            "commentSql": "ALTER TABLE s4nd_dm.\"cv_etp$projection_zs4nd_v02_all\" MODIFY COMMENT '{\n  \"app\": \"asapBI\",\n  \"descr\": \"Эффективность точек продаж\",\n  \"type\": \"VIEW\",\n  \"folder\": \"git_prj/s4nd_dm/cv\",\n  \"fields\": {\n    \"act_md_fctr_q_avg__act_months\": \"Фактор: ср. кв. значение по активным месяцам\",\n    \"act_sq_q__p_sq_per\": \"Площадь: процент от общей\",\n    \"act_sq_q__p_sq_saldo\": \"Площадь: сальдо/остаток\",\n    \"act_sq_q_avg__p_add_quarter\": \"Средняя площадь: дополнительный квартал\",\n    \"act_sq_q_avg__prev_month\": \"Средняя площадь за предыдущий месяц\",\n    \"amount\": \"Сумма в валюте транзакции\",\n    \"amount_cc\": \"Сумма в валюте компании\",\n    \"asset\": \"Инвентарный номер актива\",\n    \"asset_clas\": \"Класс основного средства\",\n    \"asset_main\": \"Группа/категория основного актива\",\n    \"bpartner\": \"Бизнес-партнёр (контрагент/субподрядчик)\",\n    \"calday\": \"Календарный день (дата)\",\n    \"calmonth\": \"Календарный месяц\",\n    \"calquart_act\": \"Актуальный/текущий квартал\",\n    \"calquart_fltr_fnl\": \"Финальный фильтр квартала\",\n    \"calquart1\": \"Дополнительное поле квартала\",\n    \"calquarter\": \"Календарный квартал\",\n    \"calyear\": \"Год календаря\",\n    \"cmmt_item\": \"Статья обязательств (Commitment Item)\",\n    \"cmmt_item__zs4citype__nav\": \"Навигационный атрибут типа статьи обязательств\",\n    \"co_area\": \"Область контроллинга (Controlling Area)\",\n    \"comp_code\": \"Код компании (Company Code)\",\n    \"curr_cc\": \"Валюта компании (Company Code Currency)\",\n    \"currency\": \"Валюта транзакции\",\n    \"flg_avg\": \"Флаг усреднения/агрегации\",\n    \"fm_area\": \"Область управления финансами (FM Area)\",\n    \"func_area\": \"Функциональная область\",\n    \"fund\": \"Фонд/источник финансирования\",\n    \"funds_ctr\": \"Центр финансирования (Fund Center)\",\n    \"infoprov\": \"Информационный провайдер (SAP BW InfoProvider)\",\n    \"md_ci