            "_lastSourceHash": "{\"sourceIds\":[],\"fieldExclusions\":[],\"fieldAliases\":{},\"selectedTable\":{\"connect_key\":\"1775066342937@@127.0.0.1@CLICKHOUSE@s4nd_dm\",\"instanceName\":\"CLICKHOUSE\",\"database\":\"s4nd_dm\",\"schema\":\"\",\"table\":\"zs4nd_v02_all\",\"dbType\":\"Clickhouse\",\"table_type\":\"TABLE\",\"metadata\":{\"table_schema\":\"s4nd_dm\",\"table_name\":\"zs4nd_v02_all\",\"table_comment\":\"{\\\"app\\\": \\\"asapBI\\\",\\r\\n \\\"descr\\\": \\\"Сборный котел данных\\\",\\r\\n \\\"folder\\\": \\\"s4nd_dm/raw\\\"\\r\\n}\",\"table_type\":\"TABLE\"},\"jsonComment\":{\"app\":\"asapBI\",\"descr\":\"Сборный котел данных\",\"folder\":\"s4nd_dm/raw\"}}}",
            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Projection_zs4nd_v02_all\n-- =========================================\n-- Блок: Projection_zs4nd_v02_all (projection)\n-- Тип: ClickHouse Parameterized View\n-- CV: cv_etp\n-- База данных: s4nd_dm\n-- =========================================\n\nCREATE OR REPLACE VIEW s4nd_dm.\"cv_etp$projection_zs4nd_v02_all\"(\n  \"act_md_fctr_q_avg__act_months\" String COMMENT 'Фактор: ср. кв. значение по активным месяцам',\n  \"act_sq_q__p_sq_per\" String COMMENT 'Площадь: процент от общей',\n  \"act_sq_q__p_sq_saldo\" String COMMENT 'Площадь: сальдо/остаток',\n  \"act_sq_q_avg__p_add_quarter\" String COMMENT 'Средняя площадь: дополнительный квартал',\n  \"act_sq_q_avg__prev_month\" String COMMENT 'Средняя площадь за предыдущий месяц',\n  \"amount\" Decimal(17, 2) COMMENT 'Сумма в валюте транзакции',\n  \"amount_cc\" Decimal(23, 2) COMMENT 'Сумма в валюте компании',\n  \"asset\" String COMMENT 'Инвентарный номер актива',\n  \"asset_clas\" String COMMENT 'Класс основного средства',\n  \"asset_main\" String COMMENT 'Группа/категория основного актива',\n  \"bpartner\" String COMMENT 'Бизнес-партнёр (контрагент/субподрядчик)',\n  \"calday\" Date COMMENT 'Календарный день (дата)',\n  \"calmonth\" String COMMENT 'Календарный месяц',\n  \"calquart_act\" String COMMENT 'Актуальный/текущий квартал',\n  \"calquart_fltr_fnl\" String COMMENT 'Финальный фильтр квартала',\n  \"calquart1\" String COMMENT 'Дополнительное поле квартала',\n  \"calquarter\" String COMMENT 'Календарный квартал',\n  \"calyear\" String COMMENT 'Год календаря',\n  \"cmmt_item\" String COMMENT 'Статья обязательств (Commitment Item)',\n  \"cmmt_item__zs4citype__nav\" String COMMENT 'Навигационный атрибут типа статьи обязательств',\n  \"co_area\" String COMMENT 'Область контроллинга (Controlling Area)',\n  \"comp_code\" String COMMENT 'Код компании (Company Code)',\n  \"curr_cc\" String COMMENT 'Валюта компании (Company Code Currency)',\n  \"currency\" String COMMENT 'Валюта транзакции',\n  \"flg_avg\" String COMMENT 'Флаг усреднения/агрегации',\n  \"fm_area\" String COMMENT 'Область управления финансами (FM Area)',\n  \"func_area\" String COMMENT 'Функциональная область',\n  \"fund\" String COMMENT 'Фонд/источник финансирования',\n  \"funds_ctr\" String COMMENT 'Центр финансирования (Fund Center)',\n  \"infoprov\" String COMMENT 'Информационный провайдер (SAP BW InfoProvider)',\n  \"md_city_all_q__p_add_quarter\" String COMMENT 'Город: дополнительный квартал',\n  \"measunit\" String COMMENT 'Единица измерения',\n  \"pu_measure\" String COMMENT 'Единица измерения/базовый показатель',\n  \"pu_measure__pu_fp_type__nav\" String COMMENT 'Навигационный атрибут типа показателя',\n  \"zalclsobj\" String COMMENT 'Объект класса аллокации',\n  \"zalclstyp\" String COMMENT 'Тип класса аллокации',\n  \"zalscenar\" String COMMENT 'Сценарий аллокации',\n  \"zalvers\" String COMMENT 'Версия аллокации',\n  \"zbwbldng\" String COMMENT 'Здание/объект недвижимости (BW)',\n  \"zbwitinf\" String COMMENT 'Инфраструктурный элемент (BW)',\n  \"zbwitsys\" String COMMENT 'IT-система/интеграция (BW)',\n  \"zmcatefct\" String COMMENT 'Фактор категории (ZMC)',\n  \"zs42lictr\" String COMMENT 'Центр затрат 2L',\n  \"zs42lsctr\" String COMMENT 'Статистический центр затрат 2L',\n  \"zs43lictr\" String COMMENT 'Центр затрат 3L',\n  \"zs43lsctr\" String COMMENT 'Статистический центр затрат 3L',\n  \"zs4aaqfr\" String COMMENT 'Фрагмент периода AAQ',\n  \"zs4ahrkv\" String COMMENT 'Ключевой индикатор/признак (Z-поле)',\n  \"zs4almdl\" String COMMENT 'Модель распределения/аллокации (Z-поле)',\n  \"zs4alrl11\" String COMMENT 'Правило аллокации 11',\n  \"zs4alrl12\" String COMMENT 'Правило аллокации 12',\n  \"zs4alrl13\" String COMMENT 'Правило аллокации 13',\n  \"zs4alrl15\" String COMMENT 'Правило аллокации 15',\n  \"zs4alrl16\" String COMMENT 'Правило аллокации 16',\n  \"zs4alrl17\" String COMMENT 'Правило аллокации 17',\n  \"zs4alrl18\" String COMMENT 'Правило аллокации 18',\n  \"zs4alrl19\" String COMMENT 'Правило аллокации 19',\n  \"zs4alsl02\" String COMMENT 'Уровень аллокации 02',\n  \"zs4alsl04\" String COMMENT 'Уровень аллокации 04',\n  \"zs4aqfrom_cy_zs4aqto\" String COMMENT 'Период AQ (текущий год)',\n  \"zs4aqfrom_zs4aqto\" String COMMENT 'Период AQ (общий диапазон)',\n  \"zs4aqfrom_zs4aqto_py\" String COMMENT 'Период AQ (предыдущий год)',\n  \"zs4bisfrb\" Nullable(String) COMMENT 'Доп. флаг/буфер BI (Nullable)',\n  \"zs4bisfrt\" String COMMENT 'Тип формата BI-отчета',\n  \"zs4bistpr\" String COMMENT 'Тип BI-отчёта/шаблона',\n  \"zs4budkyf\" String COMMENT 'Ключевой показатель бюджета',\n  \"zs4budtyp\" String COMMENT 'Тип бюджета',\n  \"zs4calqad\" String COMMENT 'Квартал года (пользовательское)',\n  \"zs4clstr1\" String COMMENT 'Кластер группировки 1',\n  \"zs4clstr2\" String COMMENT 'Кластер группировки 2',\n  \"zs4cmitex\" String COMMENT 'Текстовое описание статьи обязательств',\n  \"zs4cmmtdb\" String COMMENT 'База данных/источник обязательств',\n  \"zs4cmmtgr\" String COMMENT 'Группа статей обязательств',\n  \"zs4cmmti1\" String COMMENT 'Доп. поле статьи обязательств 1',\n  \"zs4cmmti2\" String COMMENT 'Доп. поле статьи обязательств 2',\n  \"zs4cmmti3\" String COMMENT 'Доп. поле статьи обязательств 3',\n  \"zs4cmmti4\" String COMMENT 'Доп. поле статьи обязательств 4',\n  \"zs4cmmti5\" String COMMENT 'Доп. поле статьи обязательств 5',\n  \"zs4cpacf2\" String COMMENT 'Фактор расчёта/CPA (вариант 2)',\n  \"zs4datsrc\" String COMMENT 'Источник загрузки данных',\n  \"zs4dattyp\" String COMMENT 'Тип данных/источника',\n  \"zs4depsrc\" String COMMENT 'Источник зависимостей/правило',\n  \"zs4fctr2l\" String COMMENT 'Центр затрат 2-го уровня',\n  \"zs4fctr3l\" String COMMENT 'Центр затрат 3-го уровня',\n  \"zs4flg009\" String COMMENT 'Пользовательский флаг 009',\n  \"zs4fmvers\" String COMMENT 'Версия модели FM',\n  \"zs4fnctrd\" String COMMENT 'Функциональный центр з