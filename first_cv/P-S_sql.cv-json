            "sqlScript": "-- =========================================\n-- ФУНКЦИЯ ДЛЯ БЛОКА: Semantics\n-- =========================================\n-- Блок: Semantics (semantics)\n-- ID: semantics_block\n-- CV: p_s\n-- Схема: public\n-- =========================================\n\nCREATE OR REPLACE FUNCTION demo.public.\"p_s\"(\n  p_params JSONB DEFAULT '{}'\n)\nRETURNS TABLE(\n  \"id\" BIGINT,\n  \"user_id\" UUID,\n  \"metadata\" JSONB,\n  \"created_at\" TIMESTAMP WITH TIME ZONE,\n  \"updated_at\" TIMESTAMP WITH TIME ZONE,\n  \"country_code\" CHAR,\n  \"tags\" pg_catalog.text[],\n  \"t1_f1\" VARCHAR,\n  \"status\" VARCHAR,\n  \"amount\" NUMERIC,\n  \"is_active\" BOOLEAN\n)\nSTABLE\nAS $$\nDECLARE\n  _sql TEXT;\nBEGIN\n-- Функция для блока: Semantics\n-- Тип блока: semantics\n-- CV: p_s\n-- База данных: demo\n-- Схема: public\n  _sql := $inner$\n      -- Блок: Semantics (semantics)\n      SELECT\n        \"id\",\n        \"user_id\"::pg_catalog.uuid,\n        \"metadata\",\n        \"created_at\"::pg_catalog.timestamp with time zone,\n        \"updated_at\"::pg_catalog.timestamp with time zone,\n        \"country_code\"::pg_catalog.character,\n        \"tags\"::pg_catalog.text[],\n        \"t1_f1\",\n        \"status\",\n        \"amount\",\n        \"is_active\"\n      FROM public.p_sprojection_table1_pg(p_params);\n    \n  $inner$;\n  RETURN QUERY EXECUTE _sql USING p_params;\nEND;\n$$ LANGUAGE plpgsql;\n\n\n",
