            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Projection_1\n-- =========================================\n-- Блок: Projection_1 (projection)\n-- Тип: ClickHouse Parameterized View\n-- CV: cv_test_sql\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"cv_test_sql$projection_1\" AS\nWITH step_auto AS (SELECT\n  \"docdate\",\n  \"docnum\",\n  \"docyear\",\n  \"id\",\n  \"price\"\nFROM repo_fi.allinfo_tbl)\nSELECT *\nFROM step_auto;\n"
