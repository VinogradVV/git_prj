            "uuid": "a36e4984-da7b-46bf-a94e-7e93908c4415",
            "activeTab": "sql",
            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Aggregation_10\n-- =========================================\n-- Блок: Aggregation_10 (aggregation)\n-- Тип: ClickHouse Parameterized View\n-- CV: pp_u_pa_s\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"pp_u_pa_s$aggregation_10\"(\n  \"id\" VARCHAR,\n  \"user_id\" VARCHAR,\n  \"metadata\" VARCHAR,\n  \"created_at\" VARCHAR,\n  \"updated_at\" VARCHAR,\n  \"country_code\" VARCHAR,\n  \"tags\" VARCHAR,\n  \"t1_f1\" VARCHAR,\n  \"status\" VARCHAR,\n  \"amount\" VARCHAR,\n  \"is_active\" VARCHAR,\n  \"session_id\" VARCHAR,\n  \"http_status\" VARCHAR,\n  \"ip_address\" VARCHAR,\n  \"referrer\" VARCHAR,\n  \"request_time\" VARCHAR,\n  \"response_time_ms\" VARCHAR,\n  \"url\" VARCHAR,\n  \"bytes_sent\" VARCHAR,\n  \"user_agent\" VARCHAR,\n  \"is_bot\" VARCHAR\n) AS\nWITH \nifNull({ctx:String}, '{}') AS ctx_init,\n  if(isValidJSON(ctx_init), ctx_init, '{}') AS ctx_clean,\n  isValidJSON(ctx_init) AS is_ctx_ok,\n  ifNull(JSONExtractString(ctx_clean, 'test_var'), 'Москва') AS test_var,\n  toJSONString((test_var)::Tuple(test_var String)) AS ctx,\nstep_auto AS (\nSELECT\n  \"id\" AS \"id\",\n  \"user_id\" AS \"user_id\",\n  \"metadata\" AS \"metadata\",\n  \"created_at\" AS \"created_at\",\n  \"updated_at\" AS \"updated_at\",\n  \"country_code\" AS \"country_code\",\n  \"tags\" AS \"tags\",\n  \"t1_f1\" AS \"t1_f1\",\n  \"status\" AS \"status\",\n  SUM(\"amount\") AS \"amount\",\n  \"is_active\" AS \"is_active\",\n  \"session_id\" AS \"session_id\",\n  \"http_status\" AS \"http_status\",\n  \"ip_address\" AS \"ip_address\",\n  \"referrer\" AS \"referrer\",\n  \"request_time\" AS \"request_time\",\n  \"response_time_ms\" AS \"response_time_ms\",\n  \"url\" AS \"url\",\n  \"bytes_sent\" AS \"bytes_sent\",\n  \"user_agent\" AS \"user_agent\",\n  \"is_bot\" AS \"is_bot\"\nFROM analytics.\"pp_u_pa_s$union_8\"(ctx = ctx)\nGROUP BY \"id\", \"user_id\", \"metadata\", \"created_at\", \"updated_at\", \"country_code\", \"tags\", \"t1_f1\", \"status\", \"is_active\", \"session_id\", \"http_status\", \"ip_address\", \"referrer\", \"request_time\", \"response_time_ms\", \"url\", \"bytes_sent\", \"user_agent\", \"is_bot\"\n)\nSELECT \n  \"id\",\n  \"user_id\",\n  \"metadata\",\n  \"created_at\",\n  \"updated_at\",\n  \"country_code\",\n  \"tags\",\n  \"t1_f1\",\n  \"status\",\n  \"amount\",\n  \"is_active\",\n  \"session_id\",\n  \"http_status\",\n  \"ip_address\",\n  \"referrer\",\n  \"request_time\",\n  \"response_time_ms\",\n  \"url\",\n  \"bytes_sent\",\n  \"user_agent\",\n  \"is_bot\"\nFROM step_auto;\n",
