            "sqlScript": "-- =========================================\n-- PARAMETRIZED VIEW ДЛЯ БЛОКА: Semantics\n-- =========================================\n-- Блок: Semantics (semantics)\n-- Тип: ClickHouse Parameterized View\n-- CV: test\n-- База данных: analytics\n-- =========================================\n\nCREATE OR REPLACE VIEW analytics.\"test\"(\n  \"created_at\" DateTime COMMENT 'Время создания события',\n  \"id\" UInt64 COMMENT 'Уникальный идентификатор записи',\n  \"amount\" Decimal(18, 2) COMMENT 'Сумма транзакции',\n  \"country_code\" FixedString(2) COMMENT 'Код страны',\n  \"is_active\" Nullable(Bool) COMMENT 'Флаг активности',\n  \"metadata\" Map(String, String) COMMENT 'Метаданные JSON-like',\n  \"status\" LowCardinality(String) COMMENT 'Статус обработки',\n  \"t1_f1\" String COMMENT 'Произвольное текстовое поле',\n  \"tags\" Array(String) COMMENT 'Список тегов',\n  \"user_id\" UUID COMMENT 'ID пользователя'\n) AS\nWITH {ctx:String} AS ctx,\nstep_auto AS (\nSELECT\n  \"created_at\",\n  \"id\",\n  \"amount\",\n  \"country_code\",\n  \"is_active\",\n  \"metadata\",\n  \"status\",\n  \"t1_f1\",\n  \"tags\",\n  \"user_id\"\nFROM analytics.\"test$projection_table1_ch\"(ctx = ctx)\nGROUP BY \"created_at\", \"id\", \"amount\", \"country_code\", \"is_active\", \"metadata\", \"status\", \"t1_f1\", \"tags\", \"user_id\"\n)\nSELECT \n  \"created_at\",\n  \"id\",\n  \"amount\",\n  \"country_code\",\n  \"is_active\",\n  \"metadata\",\n  \"status\",\n  \"t1_f1\",\n  \"tags\",\n  \"user_id\"\nFROM step_auto;\n",
